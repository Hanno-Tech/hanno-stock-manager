# =============================================================
# Desenvolvimento local (Docker: npm run db:up)
# =============================================================
DATABASE_URL="postgresql://estoque:estoque@localhost:5433/estoque_rapido"

# Segredo da sessão (gere: openssl rand -base64 32)
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_URL="http://localhost:3000"

# Storage de fotos — MinIO local
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio12345"
S3_BUCKET="estoque-fotos"
# URL pública dos objetos (local = endpoint/bucket)
S3_PUBLIC_URL="http://localhost:9000/estoque-fotos"

# =============================================================
# Produção (exemplo Neon + Cloudflare R2) — ver docs/DEPLOY.md
# =============================================================
# DATABASE_URL="postgresql://<user>:<pass>@<host>.neon.tech/estoque_rapido?sslmode=require"
# AUTH_SECRET="<openssl rand -base64 32>"
# AUTH_URL="https://seu-app.vercel.app"
# S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_ACCESS_KEY="<r2 access key id>"
# S3_SECRET_KEY="<r2 secret access key>"
# S3_BUCKET="estoque-fotos"
# S3_PUBLIC_URL="https://pub-<hash>.r2.dev"   # URL pública do bucket (habilitada no painel do R2)
